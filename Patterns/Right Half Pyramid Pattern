import java.util.*;

public class Main
{
	public static void main(String[] args) {
	    Scanner sc = new Scanner(System.in);
	    System.out.print("Enter a number : ");
	    int n = sc.nextInt();
	    pattern1(n);
	}
	
	static void pattern1(int n){
	    for(int row=1;row<=n;row++){
	        for(int col=1;col<=row;col++){
	            System.out.print("* ");
	        }
	        System.out.println();
	    }
	}
}
